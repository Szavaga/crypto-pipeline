# ── Secrets ───────────────────────────────────────────────────────────────────
.env

# ── Large generated data (re-created every run) ───────────────────────────────
data/*
!data/paper_ledger.csv
!data/testnet_ledger.csv
!data/paper_positions.json
!data/testnet_positions.json
!data/paper_summary.json
!data/testnet_summary.json
!data/signal_log.csv
!data/dashboard_data.json
!data/strategy_comparison.json
!data/simple_paper_state.json
!data/simple_paper_ledger.csv

# ── Models — track pkl and charts, exclude old single-model files ──────────────
models/*
!models/*_ensemble.pkl
!models/*_simple3.pkl
!models/*_simple5.pkl
!models/*_results.png

# ── Backtest output ───────────────────────────────────────────────────────────
backtest/

# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo

# ── OS / editor noise ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
