# ── Secrets ───────────────────────────────────────────────────────────────────
.env

# ── Data files — generated by server, never tracked ──────────────────────────
data/

# ── Models — track pkl and charts, exclude old single-model files ──────────────
models/*
!models/*_ensemble.pkl
!models/*_simple3.pkl
!models/*_simple5.pkl
!models/*_results.png

# ── Backtest output ───────────────────────────────────────────────────────────
backtest/

# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo

# ── OS / editor noise ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
